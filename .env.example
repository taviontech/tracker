# PostgreSQL
POSTGRES_DB=tracker
POSTGRES_USER=tracker
POSTGRES_PASSWORD=change_me

# JWT
JWT_SECRET=change_me_min_64_chars_long_random_string_for_production_use
JWT_EXPIRY_HOURS=24

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080

# Mail (SMTP) — use a Gmail App Password (not your regular password)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_gmail_app_password
CONTACT_RECIPIENT_EMAIL=your_email@example.com

# Donation wallets (leave empty to show "not available" in UI)
WALLET_BTC_MAINNET=
WALLET_ETH_ERC20=
WALLET_ETH_BEP20=
WALLET_USDT_ERC20=
WALLET_USDT_TRC20=
WALLET_USDT_BEP20=
WALLET_SOL_MAINNET=
WALLET_TON_MAINNET=
